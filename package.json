{
  "name": "meetfy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint && oxlint",
    "dev:cli": "pnpm --filter meetfy run start",
    "dev:worker": "pnpm --filter meetfy-worker run dev",
    "deploy:worker": "pnpm --filter meetfy-worker run deploy",
    "deploy:cli": "pnpm --filter meetfy run deploy",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.3.0",
    "oxlint": "1.53.0",
    "oxfmt": "0.38.0"
  },
  "keywords": [],
  "license": "ISC"
}