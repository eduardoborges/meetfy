{
  "extends": [
    "airbnb-base",
    "airbnb-typescript/base"
  ],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "rules": {
    "import/prefer-default-export": "off",
    "no-console": "off",
    "react/jsx-filename-extension": "off",
    "import/extensions": "off"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}