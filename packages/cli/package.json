{
  "name": "meetfy",
  "version": "1.0.5",
  "description": "CLI tool for creating instant meetings and reserving time in Google Calendar",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "meetfy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsx scripts/build.ts",
    "prepublishOnly": "pnpm run build",
    "lint": "oxlint",
    "deploy": "npm publish"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "meeting",
    "google-calendar",
    "typescript"
  ],
  "license": "ISC",
  "dependencies": {
    "chalk": "5.6.2",
    "clipboardy": "5.3.1",
    "commander": "14.0.3",
    "conf": "15.1.0",
    "google-auth-library": "10.6.1",
    "googleapis": "171.4.0",
    "open": "11.0.0",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "esbuild": "0.27.3",
    "oxlint": "^1.20.0",
    "tsx": "4.21.0"
  }
}